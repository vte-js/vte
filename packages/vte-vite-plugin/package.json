{
  "name": "@vte-js/vite-plugin",
  "version": "1.0.0",
  "description": "Vite plugin for Vue Token Engine - compile <style token> to CSS Variables",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@vte-js/core": "workspace:*",
    "magic-string": "^0.30.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "@vue/compiler-sfc": "^3.5.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vue": ">=3.0.0"
  },
  "keywords": ["vite", "vue", "design-tokens", "css-variables"],
  "author": "vte-js",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vte-js/vte.git",
    "directory": "packages/vte-vite-plugin"
  },
  "homepage": "https://github.com/vte-js/vte/tree/main/packages/vte-vite-plugin",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  }
}
