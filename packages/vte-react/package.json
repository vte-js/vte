{
  "name": "@vte-js/react",
  "version": "1.0.1",
  "description": "React bindings for Vue Token Engine - hooks and Provider",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@vte-js/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "react",
    "design-tokens",
    "hooks"
  ],
  "author": "vte-js",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vte-js/vte.git",
    "directory": "packages/vte-react"
  },
  "homepage": "https://github.com/vte-js/vte/tree/main/packages/vte-react",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  }
}
