{
  "name": "@vte-js/language-server",
  "version": "1.0.3",
  "description": "IDE-agnostic language server core for Vue Token Engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@vte-js/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "language-server",
    "ide",
    "design-tokens"
  ],
  "author": "vte-js",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vte-js/vte.git",
    "directory": "packages/vte-language-server"
  },
  "homepage": "https://github.com/vte-js/vte/tree/main/packages/vte-language-server",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  }
}
