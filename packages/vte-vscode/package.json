{
  "name": "@vte-js/vscode",
  "displayName": "VTE - Vue Token Engine",
  "description": "IDE support for Vue Token Engine <style token> blocks",
  "version": "1.0.3",
  "publisher": "vte-js",
  "license": "ISC",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vte-js/vte.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:vue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vte.goToTokenDefinition",
        "title": "VTE: Go to Token Definition"
      },
      {
        "command": "vte.goToClassDefinition",
        "title": "VTE: Go to Class Definition"
      },
      {
        "command": "vte.findTokenReferences",
        "title": "VTE: Find Token References"
      }
    ],
    "languages": [
      {
        "id": "vte-css",
        "aliases": [
          "VTE CSS",
          "vte-css"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vte-css",
        "scopeName": "source.css.vte",
        "path": "./syntaxes/vte-css.tmLanguage.json"
      },
      {
        "scopeName": "source.css.vte-inject",
        "path": "./syntaxes/vte-css-language.json",
        "injectTo": [
          "source.vue"
        ]
      }
    ],
    "configuration": {
      "title": "VTE",
      "properties": {
        "vte.tokenFile": {
          "type": "string",
          "default": "design-tokens.ts",
          "description": "Path to design tokens file"
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vte-js/language-server": "workspace:*",
    "esbuild": "^0.20.0",
    "typescript": "^6.0.3"
  }
}
