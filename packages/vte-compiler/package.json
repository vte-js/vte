{
  "name": "@vte-js/compiler",
  "version": "1.0.0",
  "description": "Compiler for Vue Token Engine - generates agent.json and tokens.d.ts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@vte-js/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "keywords": ["vue", "design-tokens", "compiler", "ai"],
  "author": "vte-js",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vte-js/vte.git",
    "directory": "packages/vte-compiler"
  },
  "homepage": "https://github.com/vte-js/vte/tree/main/packages/vte-compiler",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  }
}
