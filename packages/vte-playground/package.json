{
  "name": "@vte-js/playground",
  "version": "1.1.0",
  "description": "Visual debugging playground for Vue Token Engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vte-playground": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@vte-js/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "playground",
    "debug",
    "visual",
    "design-tokens"
  ],
  "author": "vte-js",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vte-js/vte.git",
    "directory": "packages/vte-playground"
  },
  "homepage": "https://github.com/vte-js/vte/tree/main/packages/vte-playground",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  }
}
