{
  "name": "vte",
  "version": "0.1.0",
  "description": "Vue Token Engine - Design Tokens First 的样式方案",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:vte-js/vte.git"
  },
  "homepage": "https://github.com/vte-js/vte",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @vte-js/core run build",
    "build:vite-plugin": "pnpm --filter @vte-js/vite-plugin run build",
    "build:language-server": "pnpm --filter @vte-js/language-server run build",
    "build:cli": "pnpm --filter @vte-js/cli run build",
    "build:compiler": "pnpm --filter @vte-js/compiler run build",
    "build:react": "pnpm --filter @vte-js/react run build",
    "build:vscode": "pnpm --filter @vte-js/vscode run build",
    "dev": "pnpm build:core && pnpm build:vite-plugin && pnpm --filter @vte-js/playground run build && node packages/vte-playground/dist/cli.js generate -o .vte-playground playground/design-tokens.ts && cd .vte-playground && npx vite",
    "dev:playground": "pnpm --filter @vte-js/playground run dev",
    "dev:demo": "pnpm --filter vte-demo-project run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run packages/vte-core",
    "test:vite-plugin": "vitest run packages/vte-vite-plugin",
    "clean": "pnpm -r run clean || true",
    "lint": "echo 'Linting not configured yet'",
    "typecheck": "pnpm -r run typecheck || true",
    "release": "pnpm -r run build && pnpm -r publish --no-git-checks",
    "release:core": "pnpm --filter @vte-js/core run build && pnpm --filter @vte-js/core publish --no-git-checks",
    "release:vite-plugin": "pnpm --filter @vte-js/vite-plugin run build && pnpm --filter @vte-js/vite-plugin publish --no-git-checks",
    "release:cli": "pnpm --filter @vte-js/cli run build && pnpm --filter @vte-js/cli publish --no-git-checks",
    "release:compiler": "pnpm --filter @vte-js/compiler run build && pnpm --filter @vte-js/compiler publish --no-git-checks",
    "release:react": "pnpm --filter @vte-js/react run build && pnpm --filter @vte-js/react publish --no-git-checks",
    "release:playground": "pnpm --filter @vte-js/playground run build && pnpm --filter @vte-js/playground publish --no-git-checks",
    "release:language-server": "pnpm --filter @vte-js/language-server run build && pnpm --filter @vte-js/language-server publish --no-git-checks",
    "release:vscode": "pnpm --filter @vte-js/vscode run build && pnpm --filter @vte-js/vscode publish --no-git-checks",
    "version:patch": "pnpm -r version patch --no-git-tag-version",
    "version:minor": "pnpm -r version minor --no-git-tag-version",
    "version:major": "pnpm -r version major --no-git-tag-version",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && pnpm -r publish --no-git-checks --access public"
  },
  "keywords": [
    "vue",
    "design-tokens",
    "css-variables",
    "vite",
    "vue3",
    "typescript",
    "style-system",
    "cross-platform"
  ],
  "author": "vte-js",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@9.0.0"
}
