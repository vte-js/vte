{
  "name": "vte",
  "version": "0.1.0",
  "description": "Vue Token Engine - Design Tokens First 的样式方案",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:vte-js/vte.git"
  },
  "homepage": "https://github.com/vte-js/vte",
  "bugs": {
    "url": "https://github.com/vte-js/vte/issues"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @vte/core run build",
    "build:vite-plugin": "pnpm --filter @vte/vite-plugin run build",
    "build:language-server": "pnpm --filter @vte/language-server run build",
    "build:cli": "pnpm --filter @vte/cli run build",
    "build:compiler": "pnpm --filter @vte/compiler run build",
    "build:react": "pnpm --filter @vte/react run build",
    "build:vscode": "pnpm --filter vte-vscode run build",
    "dev": "pnpm --filter @vte/playground run dev",
    "dev:demo": "pnpm --filter vte-demo-project run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run packages/vte-core",
    "test:vite-plugin": "vitest run packages/vte-vite-plugin",
    "clean": "pnpm -r run clean || true",
    "lint": "echo 'Linting not configured yet'",
    "typecheck": "pnpm -r run typecheck || true"
  },
  "keywords": [
    "vue",
    "design-tokens",
    "css-variables",
    "vite",
    "vue3",
    "typescript",
    "style-system",
    "cross-platform"
  ],
  "author": "vte-js",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@9.0.0"
}
